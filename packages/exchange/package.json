{
  "name": "@sierra-estates/exchange",
  "version": "1.0.0",
  "description": "Sierra Estates Exchange Sheet — Firestore message bus between Admin, Agents, and Workflows",
  "main": "./index.ts",
  "types": "./index.ts",
  "private": true,
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "firebase-admin": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.3"
  },
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./*": {
      "types": "./*.ts",
      "default": "./*.ts"
    }
  }
}
