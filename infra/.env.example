# ═══════════════════════════════════════════════════════════════════════════
# Sierra Estates — Infrastructure Environment Variables
# File: SE/infra/.env.example
# Copy to: SE/infra/.env  (NEVER commit the real .env)
# ═══════════════════════════════════════════════════════════════════════════

# ── n8n Configuration ──
N8N_PORT=5678
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http
WEBHOOK_URL=http://your-vps-ip:5678
N8N_EDITOR_BASE_URL=http://your-vps-ip:5678

# n8n Basic Auth (CHANGE THESE!)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangeMeToSomethingStrong!

# ── Timezone ──
TIMEZONE=Africa/Cairo

# ── Gemini API (for AI matching in n8n workflows) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Property Finder webhook secret (for lead ingestion) ──
PROPERTY_FINDER_WEBHOOK_SECRET=your-webhook-secret-here

# ── WhatsApp Scraper ──
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-incoming
BOT_NAME=Sierra Estates
WHATSAPP_QR_PORT=3000

# ── Firebase Admin (for Baileys container to write Firestore) ──
FIREBASE_PROJECT_ID=sierra-estates-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@sierra-estates-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Logging ──
LOG_LEVEL=info
