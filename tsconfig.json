{
  "extends": "./tsconfig.base.json",
  "compileOnSave": false,
  "files": [],
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@sierra-estates/exchange": ["./packages/exchange/exchange-client.ts"],
      "@sierra-estates/agents": ["./packages/agents/index.ts"],
      "@sierra-estates/agents-core": ["./packages/agents-core/src/index.ts"],
      "@sierra-estates/memory-engine": ["./packages/memory-engine/src/index.ts"],
      "@sierra-estates/obedian": ["./packages/obedian/src/index.ts"],
      "@sierra-estates/db": ["./packages/db/lib/index.ts"],
      "@sierra-estates/auth": ["./packages/auth"],
      "@sierra-estates/config": ["./packages/config"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "**/__tests__/**"],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./lib/db"
    },
    {
      "path": "./lib/api-client-react"
    },
    {
      "path": "./lib/api-zod"
    }
  ]
}
