# ═══════════════════════════════════════════════════════════════
# sierra estates — EXTERNAL WORKFLOWS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials

# ───────────────────────────────────────────────────────────────
# GOOGLE SHEETS (Shared by all workflows)
# ───────────────────────────────────────────────────────────────
# 1. Create a Google Cloud Service Account:
#    https://console.cloud.google.com/apis/credentials
# 2. Create new key → JSON
# 3. Save the JSON to /workflows/service-account-key.json
# 4. Export it as an env var:

GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/workflows/service-account-key.json

# Your Google Sheet ID (from the URL)
# https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
BROKER_INBOX_SHEET_ID=your_sheet_id_here

# ───────────────────────────────────────────────────────────────
# WHATSAPP SCRAPER (Workflow 01)
# ───────────────────────────────────────────────────────────────
# WhatsApp Web.js bot token (optional if using official Cloud API)
WHATSAPP_BOT_TOKEN=your_whatsapp_token_here

# ───────────────────────────────────────────────────────────────
# PROPERTY FINDER (Workflow 02 - Owner Search)
# ───────────────────────────────────────────────────────────────
# Get from Property Finder API console
PROPERTY_FINDER_API_BASE=https://api.propertyfinder.com.eg/v3
PROPERTY_FINDER_JWT_TOKEN=your_pf_jwt_token_here
PROPERTY_FINDER_COMPANY_ID=SB-EG-2024-001

# ───────────────────────────────────────────────────────────────
# WHATSAPP CLOUD API (Workflow 03 - Owner Contact)
# ───────────────────────────────────────────────────────────────
# Get from Meta Business Platform
WHATSAPP_API_URL=https://graph.instagram.com/v18.0
WHATSAPP_API_TOKEN=your_whatsapp_cloud_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# ───────────────────────────────────────────────────────────────
# SENDGRID (Workflow 04 - Email Sender)
# ───────────────────────────────────────────────────────────────
# Get from SendGrid dashboard → Settings → API Keys
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@sierra-estates.com
SENDGRID_FROM_NAME=Sierra Estates Team

# ───────────────────────────────────────────────────────────────
# FIREBASE (Workflow 05 - Unit Adder)
# ───────────────────────────────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=sierra-blu
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@sierra-blu.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://sierra-blu.firebaseio.com

# ───────────────────────────────────────────────────────────────
# LOGGING & MONITORING (Optional)
# ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# Sentry error tracking (optional)
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/123456

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ═══════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════
#
# 1. GOOGLE CLOUD SERVICE ACCOUNT
#    - Go to: https://console.cloud.google.com/apis/credentials
#    - Create new Service Account (name: "sierra-estates-workflows")
#    - Generate JSON key
#    - Save to: workflows/service-account-key.json
#    - Grant Editor access to your Google Sheet
#
# 2. PROPERTY FINDER API
#    - Login to: https://dashboard.propertyfinder.com
#    - Generate JWT token in API section
#    - Copy to PROPERTY_FINDER_JWT_TOKEN
#
# 3. WHATSAPP CLOUD API
#    - Create Meta Business Account: https://business.facebook.com
#    - Create WhatsApp Business App
#    - Get permanent access token
#    - Copy phone number ID from WhatsApp settings
#
# 4. SENDGRID
#    - Login to: https://app.sendgrid.com
#    - Create API key with Mail Send permission
#    - Copy to SENDGRID_API_KEY
#
# 5. FIREBASE
#    - Go to: https://console.firebase.google.com/project/sierra-blu/settings/serviceaccounts/adminsdk
#    - Generate new private key
#    - Copy JSON values to env vars
#
# 6. GOOGLE SHEETS SETUP
#    - Create a new Google Sheet named "Sierra Estates - Broker Inbox"
#    - Add these tabs (sheets):
#      • raw_messages
#      • owner_leads
#      • email_campaigns
#      • new_units
#    - See README.md for column structure
#
# 7. TEST CREDENTIALS
#    - Run: npm run owner-search (tests PF API)
#    - Run: npm run unit-adder (tests Firestore)
#    - Check Sheets for new rows
