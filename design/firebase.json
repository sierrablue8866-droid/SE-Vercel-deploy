{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "timeoutSeconds": 540,
      "memory": 512,
      "region": ["europe-west1"],
      "predeploy": ["pnpm -C \"$RESOURCE_DIR\" run build"]
    }
  ],
  "hosting": {
    "target": "sierra-estates-admin",
    "public": "firebase/admin-redirect",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      { "source": "**", "destination": "https://sierra-estates.net/admin", "type": 302 }
    ]
  },
  "firestore": {
    "rules": "apps/sierra-estates-realty/firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}
