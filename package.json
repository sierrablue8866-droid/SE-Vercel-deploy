{
  "name": "sierra-estates",
  "version": "1.0.0",
  "private": true,
  "description": "Sierra Estates — Luxury PropTech Platform for New Cairo",
  "workspaces": [
    "apps/*",
    "packages/*",
    "functions"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test:ci": "turbo run test:ci",
    "clean": "turbo run clean && rm -rf node_modules",
    "link:vercel": "vercel link",
    "deploy:preview": "vercel --build-env NEXT_PUBLIC_APP_ENV=preview",
    "deploy:prod": "vercel --prod",
    "deploy:firebase": "firebase deploy --only firestore:rules,storage,functions"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  }
}
