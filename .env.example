# ═══════════════════════════════════════════════════════════════
# Sierra Estates — Admin Panel Environment Variables
# ═══════════════════════════════════════════════════════════════

# GEMINI_API_KEY: Required for Gemini AI features in the admin panel.
GEMINI_API_KEY=""

# APP_URL: The URL where this admin panel is hosted.
# On Firebase Hosting: https://sierra-blu.web.app
APP_URL="https://sierra-blu.web.app"

# VITE_BACKEND_API_URL: Base URL of the Sierra Estates backend API.
# This is where admin CRUD calls go (leads, listings, agents, etc.)
# If the backend runs on the same Firebase project via Cloud Functions,
# use the Firebase Hosting URL. If on Vercel, use the Vercel URL.
VITE_BACKEND_API_URL="https://sierra-blu.web.app"

# ─── Firebase Config (sierra-blu project) ──────────────────────
# These are baked into firebase-applet-config.json, but listed here
# for reference. The admin panel reads from firebase-applet-config.json
# directly (not from env vars) because it's a Vite SPA.
