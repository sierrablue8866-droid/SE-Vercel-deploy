# ============================================================
# Sierra Estates (SE) — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.
#
# Canonical list of every variable the consolidated backend
# (apps/sierra-estates-realty + apps/api + apps/agents/* + functions/ +
# workflows/) and the root Next.js client-portal shell (src/) read.
# ============================================================

# ─── Firebase Client SDK (public; NEXT_PUBLIC_* ships to the browser) ───
# Canonical project: sierra-blu (matches .firebaserc). The Firebase Web API
# key is safe to expose in NEXT_PUBLIC_* vars; it identifies the project, not
# a user. Admin/Service-Account keys MUST stay server-side (see below).
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBZLN2jTTKV34SneGPoWRz1zoRpX5uODjs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-blu
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=941030513456
NEXT_PUBLIC_FIREBASE_APP_ID=1:941030513456:web:56209a1495d69f217086f5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ZP054BPJ8Q

# ─── Firebase Admin SDK (server-side only; NEVER expose) ───
# Project ID is the only field that's safe to mirror — it matches .firebaserc.
FIREBASE_PROJECT_ID=sierra-blu
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the 3 vars above: full service-account JSON as one string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Internal auth / service secrets ───
# SBR_SECRET_KEY is the shared secret checked by lib/server/auth-guard.ts
# (X-SBR-SECRET-KEY header / Bearer) for service + webhook callers.
SBR_SECRET_KEY=
CRON_SECRET=
# Admin API key for /api/houyez/seed and other admin-only Next.js routes on
# the root client-portal shell (src/). Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_me_to_a_long_random_string

# ─── AI / Gemini ───
GOOGLE_AI_API_KEY=
GOOGLE_GENAI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
# Selects the AI provider implementation in lib/ai.
AI_PROVIDER=
# Vertex AI (agents-core PropertyMatcherAgent — IAM/ADC auth, no API key).
# Requires GOOGLE_APPLICATION_CREDENTIALS or Workload Identity locally/in CI.
GOOGLE_CLOUD_LOCATION=europe-west1

# ─── WhatsApp — bulk outreach senders (4 dedicated numbers) ───
WABA_NUMBER_1=
WABA_NUMBER_2=
WABA_NUMBER_3=
WABA_NUMBER_4=
# Meta WhatsApp Cloud API (inbound webhook + any Cloud-API sends)
WHATSAPP_API_TOKEN=
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Branding suffix appended to outbound owner-outreach templates.
BRANDING_TAG=

# ─── WhatsApp — Twilio (outbound sending; wired in Phase 4) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Either a Messaging Service SID, or per-sender SIDs aligned with WABA_NUMBER_*.
TWILIO_MESSAGING_SERVICE_SID=

# ─── Telegram (high-priority alerts + webhook) ───
# TELEGRAM_BOT_TOKEN: Get from @BotFather (https://t.me/botfather)
# TELEGRAM_CHAT_ID: The chat ID to receive alerts; sent by /start command to the bot
# TELEGRAM_WEBHOOK_SECRET: Generated via `openssl rand -hex 32`; protects the webhook
# Must be registered with Telegram's setWebhook API before deployment
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis (distributed rate-limiting; lib/server/rate-limit.ts).
# When BOTH are set, public endpoints use a shared Redis counter across all
# serverless instances. When unset, the limiter falls back to a per-instance
# in-memory counter (looser under load, but never blocks on a Redis outage).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Airtable (lead/listing sync — both directions via /api/sync/airtable) ───
# Personal access token (create at https://airtable.com/create/tokens with
# data.records:read + data.records:write scoped to the base below).
AIRTABLE_API_KEY=
# Live base: "Sierra Estates — Inventory & CRM"
AIRTABLE_BASE_ID=appv3ichia6RSzcVY
# Tables read by the pull sync (Firestore ingestion). The export push writes
# listings to "Team Units" and CRM leads to "Leads".
AIRTABLE_TABLE_NAME=Team Units,Owners-Rent,Owners-Resale,Brokers

# ─── Google Sheets (ingestion + sync) ───
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
MASTER_SHEET_ID=
BROKER_INBOX_SHEET_ID=

# ─── Voice (Leila TTS) ───
ELEVENLABS_API_KEY=
LEILA_VOICE_ID=

# ─── Observability (Arize) ───
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=

# ─── Workflow / integration endpoints ───
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
PYTHON_API_BASE_URL=http://localhost:8000
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=
ZAPIER_CALENDAR_WEBHOOK_URL=

# ─── PropertyFinder (listing sync — /api/cron/sync-listings + apps/api worker) ───
# Next.js side (lib/propertyFinder-service.ts):
PROPERTY_FINDER_API_GATEWAY=https://gateway.propertyfinder.com/v2
PROPERTY_FINDER_CLIENT_ID=
PROPERTY_FINDER_CLIENT_SECRET=
PROPERTY_FINDER_API_KEY=
PROPERTY_FINDER_API_SECRET=
# Python worker side (apps/api/property_finder_sync.py, Cloud Run):
PROPERTY_FINDER_AUTH_TOKEN=
# GitHub Actions workflows (workflows/02-owner-search):
PROPERTY_FINDER_API_BASE=https://api.propertyfinder.com.eg/v3
PROPERTY_FINDER_JWT_TOKEN=

# ─── Email (Gmail SMTP) ───
GMAIL_USER=
GMAIL_PASS=

# ─── Maps & reCAPTCHA (client) ───
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─── App config / hosts ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_INTELLIGENCE_OS_URL=
# admin.sierra-estates.net — enables the admin host-split in middleware.ts.
ADMIN_HOST=
# Comma-separated origins allowed by CORS (lib/server/cors.ts).
ALLOWED_ORIGINS=
