{
	// Typechecks the Playwright e2e suite, which the main tsconfig does not
	// include. Playwright transpiles specs without typechecking, so without this
	// project the `satisfies AoBridge` guard in e2e/support/fake-bridge.ts (the
	// preload-drift tripwire) would never actually run. Wired into the
	// renderer-smoke CI job via `npm run typecheck:e2e`.
	"extends": "./tsconfig.json",
	"include": ["e2e/**/*.ts", "playwright.config.ts"]
}
