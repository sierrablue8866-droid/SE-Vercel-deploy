rules_version = '2';

// ════════════════════════════════════════════════════════════════════════
// SIERRA ESTATES — Firebase Storage Security Rules (Production)
// ════════════════════════════════════════════════════════════════════════
//
// Architecture:
//   /listings/{listingId}/...     — property images (public read, admin write)
//   /users/{uid}/...              — profile images (owner read/write)
//   /documents/{folder}/...       — PDFs, contracts (admin only)
//   /media/...                    — general media (authenticated read, admin write)
//   /{allPaths=**}                — everything else: denied by default
//
// Path conventions:
//   - Public listings images are world-readable (no auth needed) so the
//     frontend can display property photos without requiring login.
//   - User profile images are only accessible by the owner.
//   - Documents (contracts, brochures) are admin-only.
//   - All writes require authentication + admin/staff role.

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Helper functions ───────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email_verified == true &&
        (
          request.auth.token.email == 'a.fawzy8866@gmail.com' ||
          request.auth.token.email == 'A.fawzy8866@gmail.com'
        );
    }

    // ─── Listings images (public read, admin write) ────────────────
    // Path: listings/{listingId}/{filename}
    // Frontend displays these without auth (property photos on the site)

    match /listings/{listingId}/{allPaths=**} {
      allow read: if true;  // Public: anyone can view property images
      allow write: if isAdmin();
    }

    // ─── User profile images (owner read/write) ────────────────────
    // Path: users/{uid}/profile-{timestamp}.{ext}

    match /users/{uid}/{allPaths=**} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // ─── Documents (admin only — contracts, brochures) ─────────────
    // Path: documents/{folder}/{filename}

    match /documents/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── General media (authenticated read, admin write) ───────────
    // Path: media/{filename}

    match /media/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Default: deny everything else ─────────────────────────────

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
