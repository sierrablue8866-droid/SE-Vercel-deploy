# ============================================================
# Sierra Estates — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to version control.
#
# This file is the canonical list of every variable the app reads
# (apps/sierra-estates-realty). Keep it in sync: a CI sweep of
# `process.env.*` vs this file is the source of truth.
# ============================================================

# ─── Firebase Client SDK (public; NEXT_PUBLIC_* ships to the browser) ───
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (server-side only; NEVER expose) ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the 3 vars above: full service-account JSON as one string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Internal auth / service secrets ───
# SBR_SECRET_KEY is the shared secret checked by lib/server/auth-guard.ts
# (X-SBR-SECRET-KEY header / Bearer) for service + webhook callers.
SBR_SECRET_KEY=
CRON_SECRET=

# ─── AI / Gemini ───
GOOGLE_AI_API_KEY=
GOOGLE_GENAI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
# Selects the AI provider implementation in lib/ai.
AI_PROVIDER=
# Vertex AI (agents-core PropertyMatcherAgent — IAM/ADC auth, no API key).
# Requires GOOGLE_APPLICATION_CREDENTIALS or Workload Identity locally/in CI.
GOOGLE_CLOUD_LOCATION=europe-west1

# ─── WhatsApp — bulk outreach senders (4 dedicated numbers) ───
WABA_NUMBER_1=
WABA_NUMBER_2=
WABA_NUMBER_3=
WABA_NUMBER_4=
# Meta WhatsApp Cloud API (inbound webhook + any Cloud-API sends)
WHATSAPP_API_TOKEN=
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Branding suffix appended to outbound owner-outreach templates.
BRANDING_TAG=

# ─── WhatsApp — Twilio (outbound sending; wired in Phase 4) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Either a Messaging Service SID, or per-sender SIDs aligned with WABA_NUMBER_*.
TWILIO_MESSAGING_SERVICE_SID=

# ─── Telegram (high-priority alerts + webhook) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis (distributed rate-limiting; lib/server/rate-limit.ts).
# When BOTH are set, public endpoints use a shared Redis counter across all
# serverless instances. When unset, the limiter falls back to a per-instance
# in-memory counter (looser under load, but never blocks on a Redis outage).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# n8n Workflow Engine
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── Airtable (lead/listing ingestion) ───
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# ─── Google Sheets (ingestion + sync) ───
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
MASTER_SHEET_ID=
BROKER_INBOX_SHEET_ID=

# ─── Voice (Leila TTS) ───
ELEVENLABS_API_KEY=
LEILA_VOICE_ID=

# ─── Observability (Arize) ───
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=

# ─── Workflow / integration endpoints ───
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
PYTHON_API_BASE_URL=http://localhost:8000
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=
ZAPIER_CALENDAR_WEBHOOK_URL=

# ─── Email (Gmail SMTP) ───
GMAIL_USER=
GMAIL_PASS=

# ─── Maps & reCAPTCHA (client) ───
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ─── App config / hosts ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_INTELLIGENCE_OS_URL=
# admin.sierra-estates.net — enables the admin host-split in middleware.ts.
ADMIN_HOST=
# Comma-separated origins allowed by CORS (lib/server/cors.ts).
ALLOWED_ORIGINS=

# ─── Antigravity AI OS — Hermes + OpenClaw ───────────────────────────────────
# OpenClaw AI Gateway API Key (for Hermes agent + vector search)
EXPO_PUBLIC_OPENCLAW_KEY=

# ─── WhatsApp Business API (Hermes CRM Integration) ─────────────────────────
# Phone Number ID from Meta Developer Console
EXPO_PUBLIC_WA_PHONE_ID=
# Permanent access token for WhatsApp Business API
EXPO_PUBLIC_WA_TOKEN=
# Webhook verify token (choose any secret string, match in lib/whatsapp.ts)
EXPO_PUBLIC_WA_VERIFY_TOKEN=sierra_hermes_2026
# Agent phone number to receive lead notifications (international format, e.g. 201001234567)
EXPO_PUBLIC_AGENT_PHONE=
