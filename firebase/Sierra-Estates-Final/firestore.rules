rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, Hardened Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isBootstrappedAdmin() {
      return isEmailVerified() && (
        request.auth.token.email == "A.fawzy8866@gmail.com" || 
        request.auth.token.email == "a.fawzy8866@gmail.com" || 
        request.auth.token.email == "emeraldestatesegypt@gmail.com"
      );
    }

    function isRegisteredAdmin() {
      return isEmailVerified()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    function isAdmin() {
      return isBootstrappedAdmin() || isRegisteredAdmin();
    }

    function isStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'manager', 'agent'];
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // STANDALONE DATA SCHEMA BLUEPRINTS FOR VALIDATION
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'phone', 'interest', 'stage', 'hot', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.interest is string && data.interest.size() <= 1000
        && data.stage is string && data.stage in ['Viewing Scheduled', 'AI Matched', 'Contract Draft', 'Initial Contact', 'Negotiating']
        && data.hot is bool
        && (data.color == null || (data.color is string && data.color.size() <= 7))
        && (data.ownerId == null || (data.ownerId is string && data.ownerId.size() <= 128));
    }

    function isValidListing(data) {
      return data.keys().hasAll(['code', 'cmp', 'type', 'beds', 'area', 'price', 'ai', 'status', 'img', 'createdAt', 'updatedAt'])
        && data.keys().size() == 11
        && data.code is string && data.code.size() <= 50
        && data.cmp is string && data.cmp.size() <= 100
        && data.type is string && data.type.size() <= 50
        && data.beds is int && data.beds >= 0
        && data.area is int && data.area >= 0
        && data.price is string && data.price.size() <= 50
        && (data.ai is int || data.ai is float) && data.ai >= 0.0 && data.ai <= 10.0
        && data.status is string && data.status in ['Active', 'Review', 'Sold']
        && data.img is int;
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'price', 'location', 'type', 'beds', 'baths', 'area', 'imageUrl'])
        && data.title is string && data.title.size() <= 200
        && (data.titleAr == null || (data.titleAr is string && data.titleAr.size() <= 200));
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['name', 'desc', 'emoji', 'color', 'status', 'load', 'tasks', 'updatedAt'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() <= 100
        && data.desc is string && data.desc.size() <= 1000
        && data.emoji is string && data.emoji.size() <= 40
        && data.color is string && data.color.size() <= 10
        && data.status is string && data.status in ['Online', 'Running', 'Idle']
        && data.load is int && data.load >= 0 && data.load <= 100
        && data.tasks is int && data.tasks >= 0;
    }

    function isValidWorkflow(data) {
      return data.keys().hasAll(['name', 'status', 'runs', 'last', 'color', 'updatedAt'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() <= 100
        && (data.nameAr == null || (data.nameAr is string && data.nameAr.size() <= 100))
        && (data.desc == null || (data.desc is string && data.desc.size() <= 1000))
        && (data.descAr == null || (data.descAr is string && data.descAr.size() <= 1000))
        && data.status is string && data.status in ['active', 'warning', 'paused']
        && data.runs is int && data.runs >= 0
        && data.last is string && data.last.size() <= 100
        && data.color is string && data.color.size() <= 10;
    }

    function isValidAdminEntry(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt'])
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 200
        && data.role is string && data.role in ['Admin', 'Superadmin'];
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['sender', 'text', 'timestamp'])
        && data.keys().size() == 3
        && data.sender is string && data.sender in ['ai', 'user']
        && data.text is string && data.text.size() <= 5000;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['type', 'title', 'message', 'read', 'createdAt'])
        && data.keys().size() <= 7
        && data.type is string && data.type in ['lead', 'listing', 'error', 'system']
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 2000
        && data.read is bool
        && (data.titleAr == null || (data.titleAr is string && data.titleAr.size() <= 200))
        && (data.messageAr == null || (data.messageAr is string && data.messageAr.size() <= 2000));
    }

    // Dynamic and Secure Route Matching Rules

    match /leads/{leadId} {
      allow read: if isStaff() || isAdmin();
      allow create: if (isStaff() || isAdmin())
        && isValidId(leadId)
        && isValidLead(incoming())
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time + duration.value(24, 'h')
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow update: if (isStaff() || isAdmin())
        && isValidLead(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if (isStaff() || isAdmin())
        && isValidId(listingId)
        && isValidListing(incoming())
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time + duration.value(24, 'h')
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow update: if (isStaff() || isAdmin())
        && isValidListing(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow delete: if isStaff() || isAdmin();
    }

    // Catalog Marketplace Collections
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /units/{unitId} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /developers/{developerId} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /mediaAssets/{id} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /media/{id} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }
    match /zones/{id} {
      allow read: if true;
      allow write: if isStaff() || isAdmin();
    }

    // Users Profiles
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isStaff() || isAdmin());
      allow write: if isStaff() || isAdmin();
    }

    // Agents and Workflows Control
    match /agents/{agentId} {
      allow read: if isStaff() || isAdmin();
      allow create, update: if (isStaff() || isAdmin())
        && isValidId(agentId)
        && isValidAgent(incoming())
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow delete: if isAdmin();
    }

    match /workflows/{workflowId} {
      allow read: if isStaff() || isAdmin();
      allow create, update: if (isStaff() || isAdmin())
        && isValidId(workflowId)
        && isValidWorkflow(incoming())
        && incoming().updatedAt is timestamp
        && incoming().updatedAt <= request.time + duration.value(24, 'h');
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isStaff() || isAdmin();
    }

    match /admins/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAdmin()
        && isValidId(userId)
        && isValidAdminEntry(incoming())
        && incoming().createdAt <= request.time + duration.value(24, 'h');
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isStaff() || isAdmin();
      allow create: if (isStaff() || isAdmin())
        && isValidId(notificationId)
        && isValidNotification(incoming())
        && incoming().createdAt is timestamp
        && incoming().createdAt <= request.time + duration.value(24, 'h');
      allow update: if (isStaff() || isAdmin())
        && isValidNotification(incoming())
        && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    // CRM, Deals, Proposals & Workflows collections - Staff Access Only
    match /deals/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /sales/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /proposals/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /viewings/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /vouchers/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /activities/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /intelligence/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /concierge_selections/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /strategic_pipeline/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /partners/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /syncQueue/{id} { allow read, write: if isStaff() || isAdmin(); }
    match /syncLog/{id} { allow read, write: if isStaff() || isAdmin(); }

    // Analytics, Logs and Telemetry System Collections
    match /searches/{id} {
      allow read: if isStaff() || isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    match /system_logs/{id} {
      allow read, write: if isStaff() || isAdmin();
    }
    match /system_health/{id} {
      allow read, write: if isStaff() || isAdmin();
    }
    match /bots/{id} {
      allow read, write: if isStaff() || isAdmin();
    }
    match /bot_commands/{id} {
      allow read, write: if isStaff() || isAdmin();
    }
  }
}
