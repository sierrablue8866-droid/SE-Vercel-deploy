rules_version = '2';

// ============================================================================
// Sierra Blu — Cloud Storage Security Rules
//
// Uploads run server-side via the Admin SDK (see app/api/admin/media/upload),
// which BYPASSES these rules. These govern direct client access only.
//
// Hardening vs. the previous blanket `allow read, write: if request.auth != null`:
//   - Scopes access to the app's media/ prefix and default-denies everything else.
//
// NOTE: if public listing images are served via Storage security rules rather
// than signed download URLs, change the media read to `allow read: if true;`.
// Deploy with:  firebase deploy --only storage
// ============================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Application media (listing photos, brochures, floorplans).
    match /media/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default deny — privileged storage operations use the Admin SDK.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
