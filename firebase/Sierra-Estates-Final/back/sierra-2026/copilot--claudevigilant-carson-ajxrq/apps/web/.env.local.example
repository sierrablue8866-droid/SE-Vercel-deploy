# ══════════════════════════════════════════════════════════════════════════════
# FIREBASE CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your Firebase project values

# Firebase Project ID (from Firebase Console)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API Key (Web API Key from Firebase Console -> Settings -> General)
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key

# Firebase Auth Domain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase Database URL (if using Realtime Database)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Firebase Storage Bucket
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase Messaging Sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Firebase App ID
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Measurement ID (Google Analytics, optional)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# ══════════════════════════════════════════════════════════════════════════════
# THIRD-PARTY INTEGRATIONS
# ══════════════════════════════════════════════════════════════════════════════

# Telegram Bot Token (for Sierra AI bot)
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram Bot Username (for deep linking)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username

# SendGrid API Key (for email notifications)
SENDGRID_API_KEY=your-sendgrid-api-key

# Email sender address
SENDER_EMAIL=noreply@sierrablurealty.com

# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# Default locale (en or ar)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Application URL (for OAuth redirects, email links, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ══════════════════════════════════════════════════════════════════════════════
# 1. Create a new file named ".env.local" in /apps/web/ directory
# 2. Copy the contents of this file into .env.local
# 3. Replace all "your-*" placeholders with actual values from:
#    - Firebase Console: https://console.firebase.google.com
#    - Telegram Bot Father: https://t.me/botfather
#    - SendGrid Dashboard: https://sendgrid.com/
# 4. Restart the dev server after saving .env.local
# 5. Verify by checking browser console for Firebase initialization messages
