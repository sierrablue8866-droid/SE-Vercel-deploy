{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A prospective client interest or CRM record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Full name of the client" },
        "phone": { "type": "string", "description": "Phone number with country code" },
        "interest": { "type": "string", "description": "Property interest details" },
        "stage": { "type": "string", "enum": ["Viewing Scheduled", "AI Matched", "Contract Draft", "Initial Contact", "Negotiating"] },
        "color": { "type": "string" },
        "hot": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "phone", "interest", "stage", "hot", "createdAt", "updatedAt"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A real estate property listing mapping to compounds",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "cmp": { "type": "string", "description": "Compound name" },
        "type": { "type": "string" },
        "beds": { "type": "integer" },
        "area": { "type": "integer" },
        "price": { "type": "string" },
        "ai": { "type": "number", "description": "AI AVM rating or score" },
        "status": { "type": "string", "enum": ["Active", "Review", "Sold"] },
        "img": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "cmp", "type", "beds", "area", "price", "ai", "status", "img", "createdAt", "updatedAt"]
    },
    "Agent": {
      "title": "Agent",
      "description": "An AI agent or background runner status tracker",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "desc": { "type": "string" },
        "emoji": { "type": "string" },
        "color": { "type": "string" },
        "status": { "type": "string", "enum": ["Online", "Running", "Idle"] },
        "load": { "type": "integer" },
        "tasks": { "type": "integer" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "desc", "emoji", "color", "status", "load", "tasks", "updatedAt"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "An automation workflow node inside Sierra OS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "warning", "paused"] },
        "runs": { "type": "integer" },
        "last": { "type": "string" },
        "color": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "runs", "last", "color", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrator configuration entry mapping verified emails to roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A line of conversation from direct chat logs",
      "type": "object",
      "properties": {
        "sender": { "type": "string", "enum": ["ai", "user"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sender", "text", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An administrative notification or system alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["lead", "listing", "error", "system"] },
        "title": { "type": "string" },
        "titleAr": { "type": "string" },
        "message": { "type": "string" },
        "messageAr": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "read", "createdAt"]
    },
    "SearchLog": {
      "title": "SearchLog",
      "description": "Log of user search query inputs",
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "scope": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "isVoice": { "type": "boolean" }
      },
      "required": ["query", "scope", "timestamp"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "A system log or audit trail entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "category": { "type": "string" },
        "operator": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "category", "operator", "timestamp"]
    },
    "SystemHealth": {
      "title": "SystemHealth",
      "description": "Real-time system health metrics",
      "type": "object",
      "properties": {
        "dbLatency": { "type": "integer", "description": "Database query latency in ms" },
        "authUptime": { "type": "number", "description": "Uptime of authentication services in %" },
        "storageQuota": { "type": "integer", "description": "Used storage percentage" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["dbLatency", "authUptime", "storageQuota", "updatedAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "CRM prospective client entries"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Property asset listings registry"
    },
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Intelligent automated helper processes"
    },
    "/workflows/{workflowId}": {
      "schema": "Workflow",
      "description": "n8n background cron jobs and pipeline steps"
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "Administrator roles directory"
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Active live chat conversations"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Real-time administrative active notifications board"
    },
    "/searches/{searchId}": {
      "schema": "SearchLog",
      "description": "Query telemetry logging for service metrics"
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Chronological audit logs of system activity"
    },
    "/system_health/{metricId}": {
      "schema": "SystemHealth",
      "description": "Real-time metrics for system components"
    }
  }
}
