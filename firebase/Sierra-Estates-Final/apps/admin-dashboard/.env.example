# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Base URL of the Sierra Estates backend (apps/admin-dashboard/api)
# All admin CRUD calls go through here instead of direct Firestore access.
VITE_BACKEND_API_URL="https://sierra-2027.vercel.app"

# ─── Firebase Admin SDK (server-side backend only) ───────────────────────────
FIREBASE_SERVICE_ACCOUNT=<full service account JSON as a single-line string>
FIREBASE_PROJECT_ID=sierra-blu
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Twilio (SMS + WhatsApp via Twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+17017867675

# ─── PropertyFinder API ───────────────────────────────────────────────────────
PF_API_KEY=
PF_API_SECRET=

# ─── WhatsApp Business API (Meta) — for Hermes webhook ───────────────────────
# Phone Number ID from Meta Developer Console → WhatsApp → Getting Started
WA_PHONE_ID=
# Permanent access token (never expires) — generate in Meta System User settings
WA_TOKEN=
# Webhook verify token — must match WA_VERIFY_TOKEN in backend config
WA_VERIFY_TOKEN=sierra_hermes_2026

# ─── Hermes AI / OpenClaw ─────────────────────────────────────────────────────
# Keep this server-side ONLY — never expose in frontend
OPENCLAW_API_KEY=

# ─── Agent notification ───────────────────────────────────────────────────────
# Phone number to receive WhatsApp lead notifications (intl format: 201XXXXXXXXX)
AGENT_PHONE=
