rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "n5AwnuWrwhTm5brJJiJDU6uJunM2" ||
        (request.auth.token.email != null && (
          request.auth.token.email == "emeraldestatesegypt@gmail.com" ||
          request.auth.token.email == "Emeraldestatesegypt@gmail.com" ||
          request.auth.token.email == "a.fawzy8866@gmail.com" ||
          request.auth.token.email == "A.fawzy8866@gmail.com"
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'manager', 'agent'])
      );
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /agents/{agentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /workflows/{workflowId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /chats/{chatId} {
      allow read, write: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /searches/{searchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system_health/{metricId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
