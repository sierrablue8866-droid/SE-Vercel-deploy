{
  "name": "sierra-estates-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions — data collection and processing pipeline",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:ci": "jest --ci --passWithNoTests",
    "deploy": "npm run build && firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^14.2.0",
    "firebase-functions": "^7.3.0"
  },
  "devDependencies": {
    "jest": "^29",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
  "private": true
}
