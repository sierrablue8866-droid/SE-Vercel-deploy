{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "sierra-estates-client",
  "buildCommand": "cd ../.. && npm install && cd apps/client && npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["fra1"],
  "env": {
    "NEXT_PUBLIC_FIREBASE_API_KEY": "@sierra-firebase-api-key",
    "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": "@sierra-firebase-auth-domain",
    "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "@sierra-firebase-project-id",
    "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": "@sierra-firebase-storage-bucket",
    "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@sierra-firebase-messaging-sender-id",
    "NEXT_PUBLIC_FIREBASE_APP_ID": "@sierra-firebase-app-id"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_FIREBASE_API_KEY": "@sierra-firebase-api-key",
      "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": "@sierra-firebase-auth-domain",
      "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "@sierra-firebase-project-id",
      "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": "@sierra-firebase-storage-bucket",
      "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "@sierra-firebase-messaging-sender-id",
      "NEXT_PUBLIC_FIREBASE_APP_ID": "@sierra-firebase-app-id"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
