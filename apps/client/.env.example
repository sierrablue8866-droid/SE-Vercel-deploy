# ═══════════════════════════════════════════════════════════════════════════
# Sierra Estates — Client Portal Environment Variables
# File: SE/apps/client/.env.local (copy from .env.example)
# ═══════════════════════════════════════════════════════════════════════════

# Firebase config (NEXT_PUBLIC_* = exposed to browser, safe to commit)
# 🔒 Security enforced by Firestore rules — anon key is designed to be public.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-estates-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-estates-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-estates-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
