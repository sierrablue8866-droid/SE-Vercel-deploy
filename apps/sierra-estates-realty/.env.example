# ─── Two-domain host-split (production) ───
# When ADMIN_HOST is set, the middleware splits traffic:
#   - sierra-estates.net      → client page only (/admin redirects to admin host)
#   - admin.sierra-estates.net → admin page only (/ rewrites to /admin)
# Leave ALL THREE unset for local dev (single-domain mode).
ADMIN_HOST=admin.sierra-estates.net
CLIENT_HOST=sierra-estates.net

# Cookie domain — MUST start with a dot. Shares the session cookie across
# both subdomains so the user signs in once.
COOKIE_DOMAIN=.sierra-estates.net

# Public URLs (used by Navbar + Sidebar for cross-domain links)
NEXT_PUBLIC_CLIENT_URL=https://sierra-estates.net
NEXT_PUBLIC_ADMIN_URL=https://admin.sierra-estates.net

# ─── Firebase (client SDK — public, NEXT_PUBLIC_* prefix) ───
# Get these from Firebase Console → Project settings → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (server-only — DO NOT prefix) ───
# Option A: paste the entire service-account JSON here as a single line.
FIREBASE_SERVICE_ACCOUNT=
# Option B: leave FIREBASE_SERVICE_ACCOUNT empty and rely on
# GOOGLE_APPLICATION_CREDENTIALS (Vercel does this automatically when
# you set the env var to the path of a service-account file mounted at
# deploy time).

# ─── Session cookie signing secret (any random 32+ char string) ───
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Property Finder webhook shared secret (for /api/leads ingest) ───
# Leave unset to allow open ingest in sandbox (DEV ONLY).
PF_WEBHOOK_TOKEN=

# ─── Demo admin (used only when FIREBASE_SERVICE_ACCOUNT is unset) ───
# Email: admin@sierra-estates.net  ·  Password: sierra-admin
# See lib/auth.ts for the hardcoded values.
