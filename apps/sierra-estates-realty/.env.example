# =====================================================# Sierra Estates — Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to version control.
#
# This file is the canonical list of every variable the app reads
# (apps/sierra-estates-realty). Keep it in sync: a CI sweep of
# `process.env.*` vs this file is the source of truth.
# =====================================================
# ─── Firebase Client SDK (public; NEXT_PUBLIC_* ships to the browser) ───
# Canonical project: sierra-blu (matches .firebaserc). The Firebase Web API
# key is safe to expose in NEXT_PUBLIC_* vars; it identifies the project, not
# a user. Admin/Service-Account keys MUST stay server-side (see below).
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBZLN2jTTKV34SneGPoWRz1zoRpX5uODjs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-blu
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=941030513456
NEXT_PUBLIC_FIREBASE_APP_ID=1:941030513456:web:56209a1495d69f217086f5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ZP054BPJ8Q

# ─── Firebase Admin SDK (server-side only; NEVER expose) ───
# Project ID is the only field that's safe to mirror — it matches .firebaserc.
FIREBASE_PROJECT_ID=sierra-blu
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the 3 vars above: full service-account JSON as one string.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── Internal auth / service secrets ───
# SBR_SECRET_KEY is the shared secret checked by lib/server/auth-guard.ts
# (X-SBR-SECRET-KEY header / Bearer) for service + webhook callers.
SBR_SECRET_KEY=
CRON_SECRET=
# Admin API key for /api/houyez/seed and other admin-only Next.js routes on
# the root client-portal shell (src/). Generate with: openssl rand -hex 32
ADMIN_API_KEY=change_me_to_a_long_random_string

# ─── AI / Gemini ───
GOOGLE_AI_API_KEY=
GOOGLE_GENAI_API_KEY=
NEXT_PUBLIC_GEMINI_API_KEY=
# Selects the AI provider implementation in lib/ai.
AI_PROVIDER=
# Vertex AI (agents-core PropertyMatcherAgent — IAM/ADC auth, no API key).
# Requires GOOGLE_APPLICATION_CREDENTIALS or Workload Identity locally/in CI.
GOOGLE_CLOUD_LOCATION=europe-west1

# ─── WhatsApp — bulk outreach senders (4 dedicated numbers) ───
WABA_NUMBER_1=
WABA_NUMBER_2=
WABA_NUMBER_3=
WABA_NUMBER_4=
# Meta WhatsApp Cloud API (inbound webhook + any Cloud-API sends)
WHATSAPP_API_TOKEN=
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# Branding suffix appended to outbound owner-outreach templates.
BRANDING_TAG=

# ─── WhatsApp — Twilio (outbound sending; wired in Phase 4) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Either a Messaging Service SID, or per-sender SIDs aligned with WABA_NUMBER_*.
TWILIO_MESSAGING_SERVICE_SID=

# ─── Telegram (high-priority alerts + webhook) ───
# TELEGRAM_BOT_TOKEN: Get from @BotFather (https://t.me/botfather)
# TELEGRAM_CHAT_ID: The chat ID to receive alerts; sent by /start command to the bot
# TELEGRAM_WEBHOOK_SECRET: Generated via `openssl rand -hex 32`; protects the webhook
# Must be registered with Telegram's setWebhook API before deployment
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Upstash Redis (distributed rate-limiting; lib/server/rate-limit.ts).
# When BOTH are set, public endpoints use a shared Redis counter across all
# serverless instances. When unset, the limiter falls back to a per-instance
# in-memory counter (looser under load, but never blocks on a Redis outage).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# n8n Workflow Engine
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=


# ─── Vercel Deployment & Build Tokens ───
# Get this from your personal Vercel Account Settings -> Tokens
VERCEL_TOKEN=
# Get this from Vercel Team Settings -> General -> Organization ID
VERCEL_ORG_ID=
# The Project ID for your Client Portal (e.g., sierra-estates.net)
CLIENT_VERCEL_PROJECT_ID=
# The Project ID for your Admin Portal (e.g., admin.sierra-estates.net)
ADMIN_VERCEL_PROJECT_ID=
