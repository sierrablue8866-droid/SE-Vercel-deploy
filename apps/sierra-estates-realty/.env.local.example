# ══════════════════════════════════════════════════════════════════════════════
# SIERRA ESTATES — VERCEL ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS:
# 1. Fill in all the values marked with "your-..." below.
# 2. Go to Vercel -> Your Project -> Settings -> Environment Variables.
# 3. Copy ALL the text in this file and paste it into the FIRST "Key" input box. 
#    Vercel will automatically parse all the variables for you.
# 4. Do this for BOTH projects (some variables are for Realty, some for Admin).

# --- Firebase Project Configuration (Next.js / Realty App) ---
# Canonical project: sierra-blu (matches .firebaserc)
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sierra-blu
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBZLN2jTTKV34SneGPoWRz1zoRpX5uODjs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://sierra-blu.firebaseio.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=941030513456
NEXT_PUBLIC_FIREBASE_APP_ID=1:941030513456:web:56209a1495d69f217086f5
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-ZP054BPJ8Q

# --- Firebase Project Configuration (Vite / Admin Portal) ---
# Same project (sierra-blu), exposed via VITE_* for the Vite-based admin app.
VITE_FIREBASE_PROJECT_ID=sierra-blu
VITE_FIREBASE_API_KEY=AIzaSyBZLN2jTTKV34SneGPoWRz1zoRpX5uODjs
VITE_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=941030513456
VITE_FIREBASE_APP_ID=1:941030513456:web:56209a1495d69f217086f5
VITE_FIREBASE_MEASUREMENT_ID=G-ZP054BPJ8Q

# --- Firebase Admin SDK (Choose ONE method) ---
# Method 1: Provide the entire Service Account JSON (Recommended)
FIREBASE_SERVICE_ACCOUNT_JSON=your-service-account-json-content

# Method 2: Provide specific keys if Method 1 is not used
# FIREBASE_CLIENT_EMAIL=your-client-email
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Key-Here\n-----END PRIVATE KEY-----\n"

# --- Third-Party Integrations ---
PROPERTY_FINDER_API_KEY=your-property-finder-api-key
SBR_SECRET_KEY=your-sbr-secret-key
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your-telegram-bot-username
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=noreply@sierraestatesrealty.com

# --- Application Settings ---
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_APP_URL=https://your-production-url.vercel.app
ALLOWED_ORIGINS=https://admin.sierra-estates.net,https://sierra-estates.net,http://localhost:3000

# Application URL (for OAuth redirects, email links, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Intelligence OS console (Remix app on Cloud Run) — embedded in /admin/intelligence-os.
# Defaults to the deployed Cloud Run service if unset.
NEXT_PUBLIC_INTELLIGENCE_OS_URL=https://remix-remix-remix-sierra-estates-intelligence-os-755638710103.europe-west2.run.app

# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCTIONS
# ══════════════════════════════════════════════════════════════════════════════
# 1. Create a new file named ".env.local" in /apps/web/ directory
# 2. Copy the contents of this file into .env.local
# 3. Replace all "your-*" placeholders with actual values from:
#    - Firebase Console: https://console.firebase.google.com
#    - Telegram Bot Father: https://t.me/botfather
#    - SendGrid Dashboard: https://sendgrid.com/
# 4. Restart the dev server after saving .env.local
# 5. Verify by checking browser console for Firebase initialization messages

# Telegram webhook verification (set the same value as secret_token in setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# CORS - comma-separated allowlist of frontend origins permitted to call /api.
# Credentialed requests require explicit origins (no "*"). Include local dev
# and preview domains. Enforced by middleware.ts -> lib/server/cors.ts.
# http://localhost:5173 is the Vite dev server for the public client (Page-Refine-Motion).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://sierra-estates.net

# Agency/owner WhatsApp number (E.164, e.g. +201234567890) that receives a
# WhatsApp notification whenever a new lead is submitted via /api/leads.
# Queued through the existing WhatsApp dispatch cron; skipped silently if unset.
LEAD_NOTIFY_WHATSAPP_NUMBER=

