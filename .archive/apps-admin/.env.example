# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_BACKEND_API_URL: base URL of the Sierra-Estates-Final backend
# (apps/sierra-estates-realty). Admin CRUD calls (leads/listings/agents/
# workflows/users) go here instead of direct Firestore access.
VITE_BACKEND_API_URL="https://sierra-estates.net"

# --- Firebase Admin SDK (server-side, api/index.ts) ---
# Service account for the "sierra-blu" Firebase project, used to verify
# Firebase Auth ID tokens server-side (see api/firebaseAdmin.ts). Generate
# via Firebase Console > Project Settings > Service Accounts > Generate new
# private key. Set these as real secrets in Vercel — never commit the
# actual values or the downloaded JSON key file.
FIREBASE_PROJECT_ID="sierra-blu"
FIREBASE_CLIENT_EMAIL="MY_SERVICE_ACCOUNT_EMAIL"
FIREBASE_PRIVATE_KEY="MY_SERVICE_ACCOUNT_PRIVATE_KEY"
